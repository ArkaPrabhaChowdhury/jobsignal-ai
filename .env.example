GROQ_API_KEY=
DATABASE_URL=postgresql://user:pass@localhost:5433/cipdb
DB_PORT=5433
APP_HOST=0.0.0.0
PORT=8000
PUBLIC_INGEST_ENABLED=true
STRICT_STARTUP=false
DB_CONNECT_TIMEOUT_SECONDS=10
DB_STARTUP_RETRIES=15
DB_STARTUP_DELAY_SECONDS=2
MIN_CONFIDENCE=0.6
MAX_PAGES=3
CRAWL_DELAY_MS=1500
RAW_SAVE=false
LOG_LEVEL=INFO
EMBEDDING_MODEL=all-MiniLM-L6-v2
RUN_LOG_DB=run_logs.db
