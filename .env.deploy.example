GROQ_API_KEY=

APP_PORT=8000
DB_PORT=5433

POSTGRES_DB=cipdb
POSTGRES_USER=user
POSTGRES_PASSWORD=pass

DEPLOY_DATABASE_URL=postgresql://user:pass@db:5432/cipdb
DEPLOY_RUN_LOG_DB=/app/data/run_logs.db

PUBLIC_INGEST_ENABLED=false
STRICT_STARTUP=true
DB_CONNECT_TIMEOUT_SECONDS=10
DB_STARTUP_RETRIES=20
DB_STARTUP_DELAY_SECONDS=2

MIN_CONFIDENCE=0.6
MAX_PAGES=3
CRAWL_DELAY_MS=1500
RAW_SAVE=false
LOG_LEVEL=INFO
EMBEDDING_MODEL=hashing-384
